      "side": 1,
      "message": "Do we always need to keep this in sync with the Gerrit .bazelversion?\nIf so, is there any best-practice to keep them in-sync?",
      "range": {
        "startLine": 1,
        "startChar": 0,
        "endLine": 1,
        "endChar": 5
      },
      "revId": "235011a3be8467ba897a7122f97a62955063a1d7",
